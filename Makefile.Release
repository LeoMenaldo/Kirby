clean: compiler_clean 
	-$(DEL_FILE) release/basicenemy.o release/bossenemy.o release/brainofcthulhu.o release/cake.o release/checkpoint.o release/dukefishron.o release/enemy.o release/icegod.o release/main.o release/mainwindow.o release/gameobject.o release/player.o release/projectile.o release/tile.o release/xuehua.o release/qrc_res.o release/moc_mainwindow.o

distclean: clean 
	-$(DEL_FILE) .qmake.stash
	-$(DEL_FILE) $(DESTDIR_TARGET)
	-$(DEL_FILE) Makefile.Release

mocclean: compiler_moc_header_clean compiler_moc_objc_header_clean compiler_moc_source_clean

mocables: compiler_moc_header_make_all compiler_moc_objc_header_make_all compiler_moc_source_make_all

check: first

benchmark: first

compiler_no_pch_compiler_make_all:
compiler_no_pch_compiler_clean:
compiler_rcc_make_all: release/qrc_res.cpp
compiler_rcc_clean:
	-$(DEL_FILE) release/qrc_res.cpp
